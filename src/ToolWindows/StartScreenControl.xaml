<UserControl x:Class="StartScreen.ToolWindows.StartScreenControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StartScreen.ToolWindows"
             xmlns:controls="clr-namespace:StartScreen.ToolWindows.Controls"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:platformui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             toolkit:Themes.UseVsTheme="True"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarBorderBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextActiveBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMouseOverBackgroundBeginBrushKey}}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Search TextBox Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxBackgroundBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxTextBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="8 0"
                                SnapsToDevicePixels="True">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <imaging:CrispImage Grid.Column="0"
                                                    Moniker="{x:Static catalog:KnownMonikers.Search}"
                                                    Width="16" Height="16"
                                                    Margin="0 0 6 0"
                                                    VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxFocusedBackgroundBrushKey}}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxFocusedBorderBrushKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="Auto" MinWidth="520"/>
            <ColumnDefinition x:Name="RightColumn" Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Action buttons, search, MRU -->
        <Border Grid.Column="0"
                Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
            <DockPanel Margin="16">
                <!-- Action Bar at top -->
                <StackPanel x:Name="ActionBar" DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 24">
                    <Button Click="NewProjectButton_Click" Style="{StaticResource ActionButtonStyle}">
                        <StackPanel Orientation="Vertical" Margin="12 8">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.AddDocument}" Width="32" Height="32"/>
                            <TextBlock Text="New Project" Margin="0 4 0 0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OpenProjectButton_Click" Style="{StaticResource ActionButtonStyle}" Margin="8 0 0 0">
                        <StackPanel Orientation="Vertical" Margin="12 8">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.OpenFolder}" Width="32" Height="32"/>
                            <TextBlock Text="Open Project" Margin="0 4 0 0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OpenFolderButton_Click" Style="{StaticResource ActionButtonStyle}" Margin="8 0 0 0">
                        <StackPanel Orientation="Vertical" Margin="12 8">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.FolderOpened}" Width="32" Height="32"/>
                            <TextBlock Text="Open Folder" Margin="0 4 0 0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="CloneRepoButton_Click" Style="{StaticResource ActionButtonStyle}" Margin="8 0 0 0">
                        <StackPanel Orientation="Vertical" Margin="12 8">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.GoToSourceCode}" Width="32" Height="32"/>
                            <TextBlock Text="Clone Repo" Margin="0 4 0 0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Search Box -->
                <Grid DockPanel.Dock="Top" Margin="0 0 0 2" HorizontalAlignment="Left" Width="300">
                    <TextBox x:Name="SearchBox"
                            Height="32"
                            Style="{StaticResource SearchBoxStyle}"
                            TextChanged="SearchBox_TextChanged"/>
                    <TextBlock Text="Search recent..."
                               Margin="32 0 0 0"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxTextBrushKey}}"
                               Opacity="0.6"
                              Visibility="{Binding Text.IsEmpty, ElementName=SearchBox, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

                <!-- MRU Section -->
                <ScrollViewer x:Name="MruScroll" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Pinned Items -->
                        <TextBlock Text="Pinned"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Margin="0 0 0 8"
                                  Visibility="{Binding PinnedItems.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding PinnedItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:MruItemControl 
                                        PinToggleRequested="MruItemControl_PinToggleRequested"
                                        RemoveRequested="MruItemControl_RemoveRequested"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Recent Items (Time-Grouped) -->
                        <ItemsControl ItemsSource="{Binding GroupedMruItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <!-- Time Group Header -->
                                        <TextBlock Text="{Binding GroupName}"
                                                  FontSize="13"
                                                  FontWeight="SemiBold"
                                                  Opacity="0.7"
                                                  Margin="0 12 0 4"/>

                                        <!-- Items in this group -->
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <controls:MruItemControl 
                                                        PinToggleRequested="MruItemControl_PinToggleRequested"
                                                        RemoveRequested="MruItemControl_RemoveRequested"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                                    <!-- No search results message -->
                                    <TextBlock Text="No matching projects or solutions found."
                                               Opacity="0.5"
                                               FontSize="13"
                                               Margin="0 16 0 0"
                                               Visibility="{Binding HasNoSearchResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

        <!-- Right Pane: Links + News -->
        <Border Grid.Column="1"
                Background="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarGradientBeginBrushKey}}">
            <ScrollViewer x:Name="NewsScroll"
                          VerticalScrollBarVisibility="Auto"
                          Margin="40 16 24 16"
                          BorderThickness="0"
                          BorderBrush="Transparent"
                          Background="Transparent">
                <StackPanel>
                    <!-- Quick Links -->
                    <TextBlock Text="{Binding DiscoverySectionTitle}"
                              FontSize="24"
                              FontWeight="SemiBold"
                              Margin="0 0 0 8"/>
                    <TextBlock Margin="0 0 0 20" FontSize="13" VerticalAlignment="Center">
                        <Run Text="{Binding DiscoverySectionVersion}"/>
                        <Run Text="  "/>
                        <Hyperlink x:Name="ReleaseNotesLink" Click="ReleaseNotesLink_Click"
                                   Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ControlLinkTextBrushKey}}">
                            Release notes
                        </Hyperlink>
                    </TextBlock>

                    <!-- News Header -->
                    <Grid Margin="0 82 0 12">
                        <TextBlock Text="News"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  HorizontalAlignment="Left"/>
                        <ProgressBar Height="2" 
                                    VerticalAlignment="Bottom"
                                    IsIndeterminate="True"
                                    Visibility="{Binding IsRefreshingNews, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>

                    <!-- News Cards in flowing columns -->
                    <ItemsControl ItemsSource="{Binding NewsPosts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:NewsItemControl MinWidth="280" MaxWidth="380" Width="350" Margin="0 0 24 20"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
