<UserControl x:Class="StartScreen.ToolWindows.StartScreenControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StartScreen.ToolWindows"
             xmlns:controls="clr-namespace:StartScreen.ToolWindows.Controls"
             xmlns:helpers="clr-namespace:StartScreen.Helpers"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:platformui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             toolkit:Themes.UseVsTheme="True"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             AllowDrop="True"
             DragOver="UserControl_DragOver"
             Drop="UserControl_Drop"
             Loaded="UserControl_Loaded"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             GotKeyboardFocus="UserControl_GotKeyboardFocus">

    <UserControl.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:BoolToHiddenVisibilityConverter x:Key="BoolToHiddenVisibilityConverter"/>
        <local:RefreshingToOpacityConverter x:Key="RefreshingToOpacityConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <local:ColumnCountToWidthConverter x:Key="ColumnCountToWidthConverter"/>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarBorderBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextActiveBrushKey}}"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="MinHeight" Value="80"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               CornerRadius="4"
                               Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMouseOverBackgroundBeginBrushKey}}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMouseOverBackgroundBeginBrushKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Tab item style for News sub-tabs (Blogs / Videos) -->
        <Style x:Key="NewsTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="8 4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextActiveBrushKey}}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0 0 0 2"
                                BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static platformui:EnvironmentColors.ControlLinkTextBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMouseOverBackgroundBeginBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMouseOverBackgroundBeginBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search TextBox Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxBackgroundBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxTextBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="8 0"
                                SnapsToDevicePixels="True">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <imaging:CrispImage Grid.Column="0"
                                                    Moniker="{x:Static catalog:KnownMonikers.Search}"
                                                    Width="16" Height="16"
                                                    Margin="0 0 6 0"
                                                    VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxFocusedBackgroundBrushKey}}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxFocusedBorderBrushKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="PageScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False"
                  PreviewMouseWheel="PageScroll_PreviewMouseWheel">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="Auto" MinWidth="540"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="RightColumn" Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Action buttons, search, MRU -->
        <Border Grid.Column="0"
                Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
            <DockPanel Margin="32 24 32 24">
                <!-- Action Bar at top -->
                <StackPanel x:Name="ActionBar" DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 24"
                            PreviewKeyDown="ActionBar_PreviewKeyDown">
                    <Button Click="NewProjectButton_Click" Style="{StaticResource ActionButtonStyle}">
                        <StackPanel Orientation="Vertical" Margin="4 8">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.NewDocumentCollection}" Width="32" Height="32"/>
                            <TextBlock Text="New Project" Margin="0 4 0 0" HorizontalAlignment="Center" MaxWidth="80" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OpenProjectButton_Click" Style="{StaticResource ActionButtonStyle}" Margin="4 0 0 0">
                        <StackPanel Orientation="Vertical" Margin="4 8">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.OpenFolder}" Width="32" Height="32"/>
                            <TextBlock Text="Open Project" Margin="0 4 0 0" HorizontalAlignment="Center" MaxWidth="80" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OpenFolderButton_Click" Style="{StaticResource ActionButtonStyle}" Margin="4 0 0 0">
                        <StackPanel Orientation="Vertical" Margin="4 8">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.FolderOpened}" Width="32" Height="32"/>
                            <TextBlock Text="Open Folder" Margin="0 4 0 0" HorizontalAlignment="Center" MaxWidth="80" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Click="CloneRepoButton_Click" Style="{StaticResource ActionButtonStyle}" Margin="4 0 0 0">
                        <StackPanel Orientation="Vertical" Margin="4 8">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.GoToSourceCode}" Width="32" Height="32"/>
                            <TextBlock Text="Clone Repo" Margin="0 4 0 0" HorizontalAlignment="Center" MaxWidth="80" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AttachToProcessButton"
                            Click="AttachToProcessButton_Click"
                            PreviewMouseLeftButtonDown="AttachToProcessButton_PreviewMouseLeftButtonDown"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="4 0 0 0"
                            ToolTip="Attach to Process">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="AttachToProcessMenu">
                                <MenuItem Header="Reattach to Process"
                                          InputGestureText="Shift+Alt+P"
                                          Click="ReattachToProcessMenuItem_Click">
                                    <MenuItem.Icon>
                                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Process}" Width="16" Height="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="4 8">
                                <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Process}" Width="32" Height="32"/>
                                <TextBlock Text="Attach" Margin="0 4 0 0" HorizontalAlignment="Center" MaxWidth="80" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarBorderBrushKey}}"
                                    BorderThickness="1 0 0 0" Margin="8 0 -10 0">
                                <Path Data="M0,0 L6,0 L3,4 z"
                                      Margin="5 0 0 0"
                                      Width="6"
                                      Height="4"
                                      Stretch="Fill"
                                      Fill="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextActiveBrushKey}}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Search Box -->
                <Grid DockPanel.Dock="Top" Margin="0 25 0 6" HorizontalAlignment="Stretch">
                    <TextBox x:Name="SearchBox"
                            Height="32"
                            Style="{StaticResource SearchBoxStyle}"
                            TextChanged="SearchBox_TextChanged"
                            PreviewKeyDown="SearchBox_PreviewKeyDown"/>
                    <TextBlock Text="Search recent..."
                               Margin="32 0 0 0"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ComboBoxTextBrushKey}}"
                               Opacity="0.6"
                              Visibility="{Binding Text.IsEmpty, ElementName=SearchBox, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

                <!-- MRU Section -->
                <StackPanel x:Name="MruPanel" Focusable="False">
                        <!-- Pinned Items -->
                        <TextBlock Text="Pinned"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Opacity="0.7"
                                  Margin="0 12 0 4"
                                  Focusable="False"
                                  Visibility="{Binding PinnedItems.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                        <ItemsControl x:Name="PinnedItemsControl" ItemsSource="{Binding PinnedItems}" Focusable="False"
                                      AllowDrop="True"
                                      DragOver="PinnedItems_DragOver"
                                      Drop="PinnedItems_Drop"
                                      DragLeave="PinnedItems_DragLeave"
                                      PreviewMouseLeftButtonDown="PinnedItems_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="PinnedItems_PreviewMouseMove">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:MruItemControl 
                                        PinToggleRequested="MruItemControl_PinToggleRequested"
                                        RemoveRequested="MruItemControl_RemoveRequested"
                                        SelectionRequested="MruItemControl_SelectionRequested"
                                        FocusSearchBoxRequested="MruItemControl_FocusSearchBoxRequested"
                                        FocusDevHubRequested="MruItemControl_FocusDevHubRequested"
                                        FocusActionBarRequested="MruItemControl_FocusActionBarRequested"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Recent Items (Time-Grouped) -->
                        <ItemsControl ItemsSource="{Binding GroupedMruItems}" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Focusable="False">
                                        <!-- Time Group Header -->
                                        <TextBlock Text="{Binding GroupName}"
                                                  FontSize="13"
                                                  FontWeight="SemiBold"
                                                  Opacity="0.7"
                                                  Margin="0 12 0 4"
                                                  Focusable="False"/>

                                        <!-- Items in this group -->
                                        <ItemsControl ItemsSource="{Binding Items}" Focusable="False">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <controls:MruItemControl 
                                                        PinToggleRequested="MruItemControl_PinToggleRequested"
                                                        RemoveRequested="MruItemControl_RemoveRequested"
                                                        SelectionRequested="MruItemControl_SelectionRequested"
                                                        FocusSearchBoxRequested="MruItemControl_FocusSearchBoxRequested"
                                                        FocusDevHubRequested="MruItemControl_FocusDevHubRequested"
                                                        FocusActionBarRequested="MruItemControl_FocusActionBarRequested"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- No search results message -->
                        <TextBlock Text="No matching projects or solutions found."
                                   Opacity="0.5"
                                   FontSize="13"
                                   Margin="0 16 0 0"
                                   Visibility="{Binding HasNoSearchResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Draggable Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                      BorderThickness="1 0 0 0"
                      Cursor="SizeWE"
                      Focusable="False"
                      DragCompleted="GridSplitter_DragCompleted"/>

        <!-- Right Pane: Links + News (subtle lighter background) -->
        <Border x:Name="RightPaneBorder" Grid.Column="2"
                Background="{DynamicResource {x:Static platformui:EnvironmentColors.CommandShelfBackgroundGradientBeginBrushKey}}"
                SizeChanged="RightPaneBorder_SizeChanged">
            <DockPanel x:Name="NewsPanel" Margin="32 24 32 24" Focusable="False" LastChildFill="False">
                    <!-- Update Available Banner -->
                    <Border DockPanel.Dock="Top" Margin="0 0 0 16"
                            Padding="12 10"
                            CornerRadius="4"
                            Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.StatusInformation}"
                                                Width="16" Height="16"
                                                Margin="0 0 8 0"
                                                VerticalAlignment="Center"/>
                            <TextBlock Text="A new Visual Studio update is available."
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                            <Button Click="UpdateNowButton_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    MinWidth="0"
                                    MinHeight="0"
                                    Padding="12 4"
                                    Margin="12 0 0 0"
                                    VerticalAlignment="Center"
                                    Content="Update now"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick Links -->
                    <DockPanel DockPanel.Dock="Top" Margin="0 0 0 20">
                        <TextBlock Text="{Binding DiscoverySectionTitle}"
                                  FontSize="24"
                                  FontWeight="SemiBold"
                                  VerticalAlignment="Bottom"/>
                        <TextBlock Margin="12 0 0 4" FontSize="13" VerticalAlignment="Bottom">
                            <Run Text="{Binding DiscoverySectionVersion}"/>
                        </TextBlock>
                    </DockPanel>

                    <!-- Tip of the Day and Suggested Extension Cards -->
                    <Grid DockPanel.Dock="Top" Margin="0 32 0 32" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="1200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                        <!-- Tip of the Day Card (Left) -->
                        <Border Grid.Column="0"
                                CornerRadius="4"
                                Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
                            <DockPanel Margin="16 12">
                                <!-- Nav buttons -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top" Margin="8 0 0 0">
                                    <Button Click="PrevTipButton_Click"
                                            Style="{StaticResource IconButtonStyle}"
                                            VerticalAlignment="Center">
                                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Previous}"
                                                            Width="14" Height="14"/>
                                    </Button>
                                    <Button Click="NextTipButton_Click"
                                            Style="{StaticResource IconButtonStyle}"
                                            Margin="2 0 0 0"
                                            VerticalAlignment="Center">
                                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Next}"
                                                            Width="14" Height="14"/>
                                    </Button>
                                </StackPanel>
                                <!-- Icon -->
                                <imaging:CrispImage DockPanel.Dock="Left"
                                                    Moniker="{x:Static catalog:KnownMonikers.IntellisenseLightBulb}"
                                                    Width="28" Height="28"
                                                    Margin="0 0 12 0"
                                                    VerticalAlignment="Top"/>
                                    <!-- Text -->
                                    <StackPanel VerticalAlignment="Top">
                                        <TextBlock Text="Tip of the Day" FontSize="11" Opacity="0.5"/>
                                        <TextBlock helpers:InlineTextHelper.FormattedText="{Binding CurrentTip}"
                                                   FontSize="12" Opacity="0.8"
                                                   Margin="0 2 0 0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Suggested Extension Card (Right) -->
                        <Border Grid.Column="2"
                                CornerRadius="4"
                                Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
                            <DockPanel Margin="16 12">
                                <!-- Nav buttons -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top" Margin="8 0 0 0">
                                    <Button Click="PrevExtensionButton_Click"
                                            Style="{StaticResource IconButtonStyle}"
                                            VerticalAlignment="Center">
                                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Previous}"
                                                            Width="14" Height="14"/>
                                    </Button>
                                    <Button Click="NextExtensionButton_Click"
                                            Style="{StaticResource IconButtonStyle}"
                                            Margin="2 0 0 0"
                                            VerticalAlignment="Center">
                                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Next}"
                                                            Width="14" Height="14"/>
                                    </Button>
                                </StackPanel>
                                <!-- Icon -->
                                <imaging:CrispImage DockPanel.Dock="Left"
                                                    Moniker="{x:Static catalog:KnownMonikers.Extension}"
                                                    Width="28" Height="28"
                                                    Margin="0 0 12 0"
                                                    VerticalAlignment="Top"/>
                                    <!-- Text and Install/Installed Status -->
                                    <StackPanel VerticalAlignment="Top">
                                        <TextBlock Text="Suggested Extension" FontSize="11" Opacity="0.5"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0 2 0 0">
                                            <Run Text="{Binding CurrentSuggestedExtension.Name}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding CurrentSuggestedExtension.Description}"
                                                   FontSize="12" Opacity="0.7"
                                                   Margin="0 2 0 0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Installed badge / Install link (same slot to prevent height change) -->
                                        <Grid Margin="0 4 0 0">
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding CurrentSuggestedExtension.IsInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.StatusOK}"
                                                                    Width="12" Height="12"
                                                                    Margin="0 0 4 0"
                                                                    VerticalAlignment="Center"/>
                                                <TextBlock Text="Installed" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock FontSize="12"
                                                       Visibility="{Binding CurrentSuggestedExtension.IsInstalled, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <Hyperlink Click="InstallExtension_Click"
                                                           Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ControlLinkTextBrushKey}}">
                                                    Learn more and install...
                                                </Hyperlink>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                        </Grid>

                    <!-- Content Row: Dev Hub | News (with Blogs / Videos tabs) -->
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Dev Hub (fixed width, left) -->
                        <controls:DevHubPanel x:Name="DevHubPanelControl"
                                              Grid.Column="0"
                                              Margin="0 0 48 0"
                                              VerticalAlignment="Top"
                                              RefreshRequested="DevHubPanel_RefreshRequested"
                                              ClearFilterRequested="DevHubPanel_ClearFilterRequested"
                                              ConnectAccountRequested="DevHubPanel_ConnectAccountRequested"
                                              FocusMruRequested="DevHubPanel_FocusMruRequested"
                                              FocusNewsRequested="DevHubPanel_FocusNewsRequested"/>

                        <!-- News (flexible width, right) -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Refresh + customize float over the tab strip, right-aligned -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0 2 0 0" Panel.ZIndex="10">
                                <Button x:Name="RefreshNewsButton"
                                        Click="RefreshNewsButton_Click"
                                        Style="{StaticResource IconButtonStyle}"
                                        VerticalAlignment="Center">
                                    <Button.ToolTip>
                                        <ToolTip Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipBrushKey}}"
                                                 Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipTextBrushKey}}"
                                                 BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipBorderBrushKey}}"
                                                 BorderThickness="1"
                                                 Padding="4">
                                            <TextBlock Text="Refresh news feeds"/>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Refresh}"
                                                        Width="16" Height="16"
                                                        VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="NewsFeedsSettingsButton"
                                        Click="NewsFeedsSettings_Click"
                                        Style="{StaticResource IconButtonStyle}"
                                        Margin="4 0 0 0"
                                        VerticalAlignment="Center">
                                    <Button.ToolTip>
                                        <ToolTip Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipBrushKey}}"
                                                 Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipTextBrushKey}}"
                                                 BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipBorderBrushKey}}"
                                                 BorderThickness="1"
                                                 Padding="4">
                                            <TextBlock Text="Customize news feeds"/>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Settings}"
                                                        Width="16" Height="16"
                                                        VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>

                            <!-- Thin progress strip directly under the tab headers while refreshing -->
                            <ProgressBar Grid.Row="0" Height="2"
                                         VerticalAlignment="Top"
                                         Margin="0 28 0 0"
                                         IsIndeterminate="True"
                                         Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                                         Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ControlLinkTextBrushKey}}"
                                         BorderThickness="0"
                                         Panel.ZIndex="5"
                                         Visibility="{Binding IsRefreshingNews, Converter={StaticResource BoolToHiddenVisibilityConverter}}"/>

                            <!-- Blogs / Videos tabs -->
                            <TabControl Grid.Row="0" Grid.RowSpan="2"
                                        x:Name="NewsTabs"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        SelectionChanged="NewsTabs_SelectionChanged">
                                <!-- Blogs Tab -->
                                <TabItem x:Name="BlogsTab" Style="{StaticResource NewsTabItemStyle}">
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Blogs"/>
                                            <Ellipse Width="6" Height="6" Margin="4 0 0 0"
                                                     Fill="#FF4CAF50" VerticalAlignment="Center"
                                                     ToolTip="New blog posts since you last viewed this tab"
                                                     Visibility="{Binding HasNewBlogs, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </TabItem.Header>
                                    <StackPanel Margin="0 24 0 0">
                                        <TextBlock Text="News feeds are currently unavailable. Click refresh to try again."
                                                   TextWrapping="Wrap"
                                                   Opacity="0.6"
                                                   Margin="0 0 0 8"
                                                   Visibility="{Binding IsNewsUnavailable, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <!-- Pinned News Articles -->
                                        <TextBlock Text="Pinned"
                                                  FontSize="13"
                                                  FontWeight="SemiBold"
                                                  Opacity="0.7"
                                                  Margin="0 0 0 4"
                                                  Focusable="False"
                                                  Visibility="{Binding PinnedNewsPosts.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        <ItemsControl ItemsSource="{Binding PinnedNewsPosts}" Focusable="False"
                                                      Opacity="{Binding IsRefreshingNews, Converter={StaticResource RefreshingToOpacityConverter}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <controls:NewsItemControl Margin="0 0 12 12" Width="360"
                                                                              PinToggleRequested="NewsItemControl_PinToggleRequested"
                                                                              FocusDevHubRequested="NewsItemControl_FocusDevHubRequested"
                                                                              FocusYouTubeRequested="NewsItemControl_FocusYouTubeRequested"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- News Cards -->
                                        <ItemsControl ItemsSource="{Binding NewsPosts}" Focusable="False"
                                                      HorizontalAlignment="Left"
                                                      Opacity="{Binding IsRefreshingNews, Converter={StaticResource RefreshingToOpacityConverter}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <controls:NewsItemControl Margin="0 0 12 12" Width="360"
                                                                              PinToggleRequested="NewsItemControl_PinToggleRequested"
                                                                              FocusDevHubRequested="NewsItemControl_FocusDevHubRequested"
                                                                              FocusYouTubeRequested="NewsItemControl_FocusYouTubeRequested"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </TabItem>

                                <!-- Videos Tab -->
                                <TabItem x:Name="VideosTab" Style="{StaticResource NewsTabItemStyle}">
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Videos"/>
                                            <Ellipse Width="6" Height="6" Margin="4 0 0 0"
                                                     Fill="#FF4CAF50" VerticalAlignment="Center"
                                                     ToolTip="New videos since you last viewed this tab"
                                                     Visibility="{Binding HasNewVideos, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </TabItem.Header>
                                    <StackPanel Margin="0 24 0 0">
                                        <TextBlock Text="YouTube feed is currently unavailable. Click refresh to try again."
                                                   TextWrapping="Wrap"
                                                   Opacity="0.6"
                                                   Margin="0 0 0 8"
                                                   Visibility="{Binding IsYouTubeUnavailable, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <ItemsControl ItemsSource="{Binding YouTubeVideos}" Focusable="False"
                                                      HorizontalAlignment="Left"
                                                      Opacity="{Binding IsRefreshingYouTube, Converter={StaticResource RefreshingToOpacityConverter}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <controls:YouTubeVideoControl Margin="0 0 12 16" Width="360"
                                                                                   FocusNewsRequested="YouTubeVideoControl_FocusNewsRequested"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </TabItem>

                                <!-- Release Notes Tab -->
                                <TabItem x:Name="ReleaseNotesTab" Style="{StaticResource NewsTabItemStyle}">
                                    <TabItem.Header>
                                        <TextBlock Text="Release notes"/>
                                    </TabItem.Header>
                                    <StackPanel Margin="0 24 0 0">
                                        <TextBlock TextWrapping="Wrap">
                                            <Hyperlink x:Name="ReleaseNotesLink" Click="ReleaseNotesLink_Click"
                                                       Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ControlLinkTextBrushKey}}">
                                                View release notes for <Run Text="{Binding DiscoverySectionVersion}"/>
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </TabItem>
                            </TabControl>

                        </Grid>

                    </Grid>
            </DockPanel>
        </Border>
    </Grid>
    </ScrollViewer>

        <!-- Settings gear (top-right overlay) -->
        <Button x:Name="StartScreenSettingsButton"
                Click="StartScreenSettingsButton_Click"
                Style="{StaticResource IconButtonStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0 8 24 0"
                Panel.ZIndex="10">
            <Button.ToolTip>
                <ToolTip Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipBrushKey}}"
                         Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipBorderBrushKey}}"
                         BorderThickness="1"
                         Padding="4">
                    <TextBlock Text="Start Screen settings"/>
                </ToolTip>
            </Button.ToolTip>
            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Settings}"
                                Width="16" Height="16"
                                VerticalAlignment="Center"/>
        </Button>

        <Popup x:Name="StartScreenSettingsPopup"
               PlacementTarget="{Binding ElementName=StartScreenSettingsButton}"
               Placement="Bottom"
               HorizontalOffset="-220"
               VerticalOffset="2"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarBorderBrushKey}}"
                    BorderThickness="1"
                    Padding="12">
                <StackPanel MinWidth="260">
                    <TextBlock Text="Start Screen settings"
                               FontWeight="SemiBold"
                               Margin="0 0 0 8"/>
                    <CheckBox x:Name="KeepVisibleCheckBox"
                              Content="Keep visible when a solution loads"
                              Checked="KeepVisibleCheckBox_Changed"
                              Unchecked="KeepVisibleCheckBox_Changed"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
