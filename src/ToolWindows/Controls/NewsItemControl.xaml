<UserControl x:Class="StartScreen.ToolWindows.Controls.NewsItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:platformui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             toolkit:Themes.UseVsTheme="True"
             Background="Transparent"
             Focusable="False"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="380">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Border x:Name="RootBorder"
            BorderThickness="0"
            Background="Transparent"
            Padding="8"
            CornerRadius="4"
            Focusable="True"
            FocusVisualStyle="{x:Null}"
            MouseEnter="RootBorder_MouseEnter"
            MouseLeave="RootBorder_MouseLeave"
            MouseUp="RootBorder_MouseUp"
            KeyDown="RootBorder_KeyDown"
            GotKeyboardFocus="RootBorder_GotKeyboardFocus"
            LostKeyboardFocus="RootBorder_LostKeyboardFocus"
            Cursor="Hand">
        <Grid>
            <StackPanel Orientation="Vertical" Margin="0 0 24 0">
                <!-- Title -->
                <TextBlock Text="{Binding Title}"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ControlLinkTextBrushKey}}"
                          TextWrapping="Wrap"
                          FontSize="13"/>

                <!-- Summary -->
                <TextBlock Text="{Binding Summary}"
                          Opacity="0.7"
                          TextWrapping="Wrap"
                          TextTrimming="WordEllipsis"
                          MaxHeight="40"
                          Margin="0 6 0 6"/>

                <!-- Source and Date -->
                <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                    <TextBlock Text="NEW"
                               FontWeight="Bold"
                               FontSize="10"
                               Foreground="#FF4CAF50"
                               Margin="0 0 6 0"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Source}"
                              Opacity="0.5"
                              FontSize="11"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Pin Button (bottom right, visible on hover or when pinned) -->
            <Button x:Name="PinButton"
                    Width="24" Height="24"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Focusable="False"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0 0 -4 -4"
                    Visibility="Collapsed"
                    Click="PinButton_Click">
                <imaging:CrispImage x:Name="PinIcon" Moniker="{x:Static catalog:KnownMonikers.Pin}" Width="16" Height="16"/>
            </Button>
        </Grid>

        <!-- Context Menu -->
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Open in Browser" Click="OpenInBrowserMenuItem_Click" InputGestureText="Enter"/>
                <Separator/>
                <MenuItem Header="Copy URL" Click="CopyUrlMenuItem_Click" InputGestureText="Ctrl+C"/>
            </ContextMenu>
        </Border.ContextMenu>
    </Border>
</UserControl>
