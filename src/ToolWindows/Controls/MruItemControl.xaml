<UserControl x:Class="StartScreen.ToolWindows.Controls.MruItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:platformui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:controls="clr-namespace:StartScreen.ToolWindows.Controls"
             toolkit:Themes.UseVsTheme="True"
             Background="Transparent"
             Focusable="False"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <controls:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
    </UserControl.Resources>
    <Border x:Name="RootBorder"
            BorderThickness="0"
            Background="Transparent"
            Padding="8 6"
            CornerRadius="4"
            Cursor="Hand"
            Focusable="True"
            FocusVisualStyle="{x:Null}"
            MouseEnter="RootBorder_MouseEnter"
            MouseLeave="RootBorder_MouseLeave"
            MouseUp="RootBorder_MouseUp"
            KeyDown="RootBorder_KeyDown"
            GotKeyboardFocus="RootBorder_GotKeyboardFocus"
            LostKeyboardFocus="RootBorder_LostKeyboardFocus">
        <Border.ToolTip>
            <ToolTip Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipBrushKey}}"
                     Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipTextBrushKey}}"
                     BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.ToolTipBorderBrushKey}}"
                     BorderThickness="1"
                     Padding="4">
                <StackPanel>
                    <!-- Path (bold) -->
                    <TextBlock Text="{Binding Path}" 
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               MaxWidth="400"/>

                    <!-- Last opened -->
                    <StackPanel Orientation="Horizontal" Margin="0 6 0 0">
                        <TextBlock Text="Last opened: " Opacity="0.7"/>
                        <TextBlock Text="{Binding FormattedDate}"/>
                    </StackPanel>

                    <!-- Git info section -->
                    <StackPanel Margin="0 2 0 0"
                                Visibility="{Binding HasGitBranch, Converter={StaticResource BoolToVisibilityConverter}}">
                        <!-- Branch -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Branch: " Opacity="0.7"/>
                            <TextBlock Text="{Binding GitBranch}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AheadBehindText}" 
                                       Margin="6 0 0 0"
                                       Visibility="{Binding HasAheadBehind, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text=" ●" 
                                       Foreground="#E8A838" 
                                       FontSize="10"
                                       ToolTip="Uncommitted changes"
                                       Visibility="{Binding HasUncommittedChanges, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Last commit -->
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0 2 0 0"
                                    Visibility="{Binding LastCommitTime, Converter={StaticResource NullToCollapsedConverter}}">
                            <TextBlock Text="Last commit: " Opacity="0.7"/>
                            <TextBlock Text="{Binding LastCommitTimeText}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ToolTip>
        </Border.ToolTip>
        <DockPanel>
            <!-- Right side: Git info and pin -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Git status (right-aligned) -->
                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center"
                            Margin="12 0 0 0"
                            Visibility="{Binding HasGitBranch, Converter={StaticResource BoolToVisibilityConverter}}">
                    <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Branch}"
                                        Width="12" Height="12"
                                        Margin="0 0 4 0"
                                        Opacity="0.6"
                                        VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GitBranch}"
                              FontSize="11"
                              Opacity="0.6"
                              VerticalAlignment="Center"
                              TextTrimming="CharacterEllipsis"
                              MaxWidth="100"/>

                    <!-- Ahead/Behind indicators -->
                    <TextBlock Text="{Binding AheadBehindText}"
                              FontSize="11"
                              Opacity="0.6"
                              Margin="6 0 0 0"
                              VerticalAlignment="Center"
                              Visibility="{Binding HasAheadBehind, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Uncommitted changes indicator -->
                    <TextBlock Text="●"
                              FontSize="9"
                              Foreground="#E8A838"
                              Margin="6 0 0 2"
                              VerticalAlignment="Center"
                              ToolTip="Uncommitted changes"
                              Visibility="{Binding HasUncommittedChanges, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Pin Button -->
                <Button x:Name="PinButton"
                       Width="24" Height="24"
                       Background="Transparent"
                       BorderThickness="0"
                       Cursor="Hand"
                       Focusable="False"
                       VerticalAlignment="Center"
                       Margin="4 0 0 0"
                       ToolTip="Pin/Unpin"
                       Click="PinButton_Click">
                    <imaging:CrispImage x:Name="PinIcon" Moniker="{x:Static catalog:KnownMonikers.Pin}" Width="16" Height="16"/>
                </Button>
            </StackPanel>

            <!-- Icon -->
            <imaging:CrispImage x:Name="Icon" DockPanel.Dock="Left"
                              Width="24" Height="24"
                              Margin="0 0 8 0"
                              VerticalAlignment="Center"/>

            <!-- Solution/Project Name -->
            <TextBlock x:Name="NameText"
                      Text="{Binding Name}"
                      FontWeight="SemiBold"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextActiveBrushKey}}"
                      TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- Context Menu -->
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Open" Click="OpenMenuItem_Click" InputGestureText="Enter"/>
                <MenuItem Header="Open in New Instance" Click="OpenInNewInstanceMenuItem_Click" InputGestureText="Ctrl+Enter"/>
                <MenuItem Header="Open Containing Folder" Click="OpenFolderMenuItem_Click" InputGestureText="O"/>
                <MenuItem Header="Open in Terminal" Click="OpenTerminalMenuItem_Click" InputGestureText="T"/>
                <Separator/>
                <MenuItem Header="Copy Path" Click="CopyPathMenuItem_Click" InputGestureText="Ctrl+C"/>
                <Separator/>
                <MenuItem Header="Pin" Click="PinMenuItem_Click" InputGestureText="P"/>
                <MenuItem Header="Remove from List" Click="RemoveMenuItem_Click" InputGestureText="Del"/>
            </ContextMenu>
        </Border.ContextMenu>
    </Border>
</UserControl>
