<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <UseWPF>true</UseWPF>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>

    <!-- VSIX settings -->
    <VSSDKBuildToolsAutoSetup>true</VSSDKBuildToolsAutoSetup>
    <VsixDeployOnDebug>true</VsixDeployOnDebug>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
  </PropertyGroup>

  <ItemGroup>
    <ProjectCapability Include="CreateVsixContainer" />
  </ItemGroup>

  <!-- Auto-generated files (use Update because SDK auto-includes *.cs) -->
  <ItemGroup>
    <Compile Update="source.extension.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>source.extension.vsixmanifest</DependentUpon>
    </Compile>
    <Compile Update="VSCommandTable.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>VSCommandTable.vsct</DependentUpon>
    </Compile>
  </ItemGroup>

  <!-- XAML code-behind files (use Update for DependentUpon metadata) -->
  <ItemGroup>
    <Compile Update="ToolWindows\Controls\DevHubPanel.xaml.cs">
      <DependentUpon>DevHubPanel.xaml</DependentUpon>
    </Compile>
    <Compile Update="ToolWindows\StartScreenControl.xaml.cs">
      <DependentUpon>StartScreenControl.xaml</DependentUpon>
    </Compile>
    <Compile Update="ToolWindows\Controls\MruItemControl.xaml.cs">
      <DependentUpon>MruItemControl.xaml</DependentUpon>
    </Compile>
    <Compile Update="ToolWindows\Controls\NewsItemControl.xaml.cs">
      <DependentUpon>NewsItemControl.xaml</DependentUpon>
    </Compile>
    <Compile Update="ToolWindows\Controls\YouTubeVideoControl.xaml.cs">
      <DependentUpon>YouTubeVideoControl.xaml</DependentUpon>
    </Compile>
  </ItemGroup>

  <!-- VSCT command table -->
  <ItemGroup>
    <AvailableItemName Include="VSCTCompile" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="VSCommandTable.vsct" />
    <VSCTCompile Include="VSCommandTable.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
      <Generator>VsctGenerator</Generator>
      <LastGenOutput>VSCommandTable.cs</LastGenOutput>
    </VSCTCompile>
  </ItemGroup>

  <!-- VSIX manifest -->
  <ItemGroup>
    <None Update="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
      <Generator>VsixManifestGenerator</Generator>
      <LastGenOutput>source.extension.cs</LastGenOutput>
      <IncludeInVSIX>True</IncludeInVSIX>
    </None>
  </ItemGroup>

  <!-- XAML pages: UseWPF auto-globs *.xaml as Page, just add metadata -->
  <ItemGroup>
    <Page Update="ToolWindows\Controls\DevHubPanel.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="ToolWindows\StartScreenControl.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="ToolWindows\Controls\MruItemControl.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="ToolWindows\Controls\NewsItemControl.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="ToolWindows\Controls\YouTubeVideoControl.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>

  <!-- Embedded resources (not auto-globbed unless *.resx) -->
  <ItemGroup>
    <None Remove="Resources\extensions.json;Resources\newsfeeds.json;Resources\tips.txt" />
    <EmbeddedResource Include="Resources\extensions.json" />
    <EmbeddedResource Include="Resources\newsfeeds.json" />
    <EmbeddedResource Include="Resources\tips.txt" />
  </ItemGroup>

  <!-- Resources included in VSIX -->
  <ItemGroup>
    <Content Include="..\LICENSE.txt">
      <Link>Resources\LICENSE.txt</Link>
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Resources\Icon.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="StartScreenPackage.cs">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- .NET Framework assemblies not covered by NuGet packages -->
  <ItemGroup>
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="System.ComponentModel.Composition" />
    <Reference Include="System.Design" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.ServiceModel" />
    <Reference Include="System.Xaml" />
    <Reference Include="WindowsBase" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Community.VisualStudio.VSCT" Version="16.0.29.14" PrivateAssets="all" />
    <PackageReference Include="Community.VisualStudio.Toolkit.17" Version="17.0.551" ExcludeAssets="Runtime">
      <IncludeAssets>compile; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="LibGit2Sharp" Version="0.31.0" />
    <!--<PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.0.32112.339" ExcludeAssets="runtime">
      <IncludeAssets>compile; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>-->
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="18.5.40034">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="System.Text.Json" Version="4.7.2" />
  </ItemGroup>

</Project>
